{
  "entities": {
    "Customer": {
      "title": "Customer",
      "description": "B2B Customer details and relationship status",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "description": "Name of the customer company" },
        "ownerId": { "type": "string", "description": "UID of the sales agent owning this account" },
        "status": { "type": "string", "enum": ["Deal", "Negosiasi", "Menolak"] },
        "relationshipScore": { "type": "number", "description": "Points reflecting relationship depth" },
        "rsLevel": { "type": "string", "enum": ["Cold", "Warm", "Engaged", "Trusted", "Loyal"] },
        "probability": { "type": "number", "description": "Probability of deal closing (%)" },
        "revenue": { "type": "number" },
        "industry": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "ownerId", "status", "relationshipScore", "rsLevel", "probability", "createdAt", "updatedAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Interactions logged with customers",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "ownerId": { "type": "string" },
        "points": { "type": "number" },
        "notes": { "type": "string" }
      },
      "required": ["customerId", "type", "date", "ownerId", "points"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Planned future meetings or visits",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "ownerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["customerId", "type", "date", "ownerId", "status"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["sales", "admin"] }
      },
      "required": ["id", "email", "name", "role"]
    }
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "Customer",
      "description": "Sales accounts"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Log of interactions"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Future appointments"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles"
    }
  }
}
